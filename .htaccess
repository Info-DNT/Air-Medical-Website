# --- Redirect Country Listing ---
Redirect 301 /country.html /countries/index.html

# --- Redirect Service Pages ---
Redirect 301 /air-ambulance.html /services/air-ambulance.html
Redirect 301 /air-ambulance-charters.html /services/air-ambulance-charters.html
Redirect 301 /commercial-airlines-medical-transfer-services.html /services/commercial-airlines-medical-transfer-services.html
