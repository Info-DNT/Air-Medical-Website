Redirect 301 /air-ambulance-argentina.html /countries/air-ambulance-argentina.html
Redirect 301 /air-ambulance-armenia.html /countries/air-ambulance-armenia.html
Redirect 301 /air-ambulance-australia.html /countries/air-ambulance-australia.html
Redirect 301 /air-ambulance-austria.html /countries/air-ambulance-austria.html
