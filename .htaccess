# Air Medical 24X7 - Clean URL Mappings & Performance Routing
RewriteEngine On
RewriteBase /

# 1. Enforce clean URLs: Redirect direct requests for .html files to extensionless URLs
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteCond %{REQUEST_URI} !^/admin\.html$ [NC]
RewriteRule ^ /%1 [R=301,L]

# 2. Redirect legacy root service/country pages to their new clean subdirectory counterparts
RewriteRule ^airline-stretcher-services$ /services/commercial-flight-stretcher [R=301,L,NC]
RewriteRule ^commercial-flight-stretcher$ /services/commercial-flight-stretcher [R=301,L,NC]
RewriteRule ^air-ambulance$ /services/air-ambulance [R=301,L,NC]
RewriteRule ^air-ambulance-charters$ /services/air-ambulance-charters [R=301,L,NC]
RewriteRule ^flight-medical-escort-services$ /services/flight-medical-escort-services [R=301,L,NC]
RewriteRule ^hospital-acceptance$ /services/hospital-acceptance [R=301,L,NC]
RewriteRule ^doctor-appointment$ /services/doctor-appointment [R=301,L,NC]
RewriteRule ^second-opinion-services$ /services/second-opinion-services [R=301,L,NC]
RewriteRule ^custom-medical-packages$ /services/custom-medical-packages [R=301,L,NC]
RewriteRule ^ecmo-transfer$ /services/ECMO-transfer [R=301,L,NC]
RewriteRule ^commercial-airlines-medical-transfer-services$ /services/commercial-airlines-medical-transfer-services [R=301,L,NC]
RewriteRule ^medical-tourism-services$ /services/medical-tourism-services [R=301,L,NC]

# Redirect root country pages to countries subdirectory clean routes
RewriteRule ^air-ambulance-(dubai|india|cost-dubai|to-india)$ /countries/air-ambulance-$1 [R=301,L,NC]

# 3. Internal Clean URL Routing: Map clean URLs internally to physical .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [L]
