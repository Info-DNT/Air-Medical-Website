# Air Medical 24X7 - 301 Redirects for Restructured Folders
RewriteEngine On
# --- Clean URLs (remove .html) ---
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+)$ $1.html [L]

# Redirect .html requests to clean URLs
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
RewriteRule ^ /%1 [R=301,L]
# --- Redirect Country Pages ---
Redirect 301 /air-ambulance-afghanistan.html /countries/air-ambulance-afghanistan.html
Redirect 301 /air-ambulance-albania.html /countries/air-ambulance-albania.html
Redirect 301 /air-ambulance-algeria.html /countries/air-ambulance-algeria.html
