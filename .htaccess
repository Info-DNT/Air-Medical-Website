# Air Medical 24X7 - Physical URL Mappings & Legacy Clean URL Redirects
RewriteEngine On
RewriteBase /

# 1. Permanent 301 redirects for legacy clean URLs to their physical counterparts
# This protects SEO ranking and prevents 404s for indexed pages.

# Redirect legacy airline-stretcher-services to commercial-flight-stretcher.html
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^airline-stretcher-services(?:\.html)?$ /services/commercial-flight-stretcher.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^commercial-flight-stretcher$ /services/commercial-flight-stretcher.html [R=301,L,NC]

# Redirect clean core page URLs
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^about-us$ /about-us.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^contact-us$ /contact-us.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^career$ /career.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^blogs$ /blogs.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^blogs-detail$ /blogs-detail.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^countries$ /countries.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^privacy-policy$ /privacy-policy.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^terms-and-conditions$ /terms-and-conditions.html [R=301,L,NC]

# Redirect clean service URLs to the services/ folder
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^air-ambulance$ /services/air-ambulance.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^air-ambulance-charters$ /services/air-ambulance-charters.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^flight-medical-escort-services$ /services/flight-medical-escort-services.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^hospital-acceptance$ /services/hospital-acceptance.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^doctor-appointment$ /services/doctor-appointment.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^second-opinion-services$ /services/second-opinion-services.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^custom-medical-packages$ /services/custom-medical-packages.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^ecmo-transfer$ /services/ECMO-transfer.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^commercial-airlines-medical-transfer-services$ /services/commercial-airlines-medical-transfer-services.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^medical-tourism-services$ /services/medical-tourism-services.html [R=301,L,NC]

# Redirect custom root service pages
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^commercial-stretcher-service$ /commercial-stretcher-service.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^ecmo-air-transfer$ /ecmo-air-transfer.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^medical-escort-dubai$ /medical-escort-dubai.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^medical-tourism-india$ /medical-tourism-india.html [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^repatriation-services-dubai$ /repatriation-services-dubai.html [R=301,L,NC]

# Redirect clean country URLs to countries/ folder
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^air-ambulance-(dubai|india|cost-dubai|to-india)$ /countries/air-ambulance-$1.html [R=301,L,NC]

# Generic fallback for standard country pages (air-ambulance-[country])
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{DOCUMENT_ROOT}/countries/air-ambulance-$1.html -f
RewriteRule ^air-ambulance-([a-z\-]+)$ /countries/air-ambulance-$1.html [R=301,L,NC]

# Force admin routing to lowercase admin.html
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^[Aa]dmin$ /admin.html [R=301,L]
