# Air Medical 24X7 - Clean URL Rewrites & Redirects
RewriteEngine On
RewriteBase /

# Directory conflict override for countries listing
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^countries/?$ countries.html [L,NC]

# 1. Redirect legacy/physical subdirectory paths to clean root-level URLs
# Use %{ENV:REDIRECT_STATUS} to avoid redirect loops on internal rewrites
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^countries/index(?:\.html)?$ /countries [R=301,L,NC]

RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^countries/(.+?)(?:\.html)?$ /$1 [R=301,L,NC]

RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^services/(.+?)(?:\.html)?$ /$1 [R=301,L,NC]

# Redirect legacy about.html and contact.html
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^about(?:\.html)?$ /about-us [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^contact(?:\.html)?$ /contact-us [R=301,L,NC]

# Redirect legacy singular URLs to plural
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^flight-medical-escort-service(?:\.html)?$ /flight-medical-escort-services [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^blog(?:\.html)?$ /blogs [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^blog-detail(?:\.html)?$ /blogs-detail [R=301,L,NC]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^country(?:\.html)?$ /countries [R=301,L,NC]

# 2. Redirect root-level .html requests to clean URLs
RewriteCond %{THE_REQUEST} \s/([^/]+)\.html [NC]
RewriteRule ^([^/]+)\.html$ /$1 [R=301,L]

# 3. Internal Rewrite: Route clean root URLs to their physical subdirectory paths
# Check in countries/ folder
RewriteCond %{DOCUMENT_ROOT}/countries/$1.html -f
RewriteRule ^([^/]+)$ countries/$1.html [L]

# Check in services/ folder
RewriteCond %{DOCUMENT_ROOT}/services/$1.html -f
RewriteRule ^([^/]+)$ services/$1.html [L]

# Check in root folder
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^/]+)$ $1.html [L]
